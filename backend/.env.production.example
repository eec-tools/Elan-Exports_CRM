# Production Environment Variables
# Copy these to your Render.com dashboard

NODE_ENV=production

# Frontend URL - Add all allowed origins (comma-separated)
FRONTEND_URL=https://elan-exports-crm.vercel.app,https://your-custom-domain.com

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:password@host.neon.tech/neondb?sslmode=require

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_256_BIT_RANDOM
JWT_EXPIRES_IN=7d

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your-company-email@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Server Configuration
PORT=3001

# Optional: Cloudinary (if using file uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Gmail OAuth (Sourcing Supplier Campaigns)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
# MUST match exactly what's registered in Google Cloud Console Authorized Redirect URIs
GMAIL_REDIRECT_URI=http://13.205.249.8:3001/api/gmail/callback
# The Gmail accounts used to send campaigns
GMAIL_ACCOUNT_1_EMAIL=account1@gmail.com
GMAIL_ACCOUNT_2_EMAIL=account2@gmail.com
GMAIL_ACCOUNT_3_EMAIL=account3@gmail.com
