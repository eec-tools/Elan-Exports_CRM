# Production Environment Variables
# Copy these to your Render.com dashboard

NODE_ENV=production

# Frontend URL - Add all allowed origins (comma-separated)
FRONTEND_URL=https://elan-exports-crm.vercel.app,https://your-custom-domain.com

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:password@host.neon.tech/neondb?sslmode=require

# JWT Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_256_BIT_RANDOM
JWT_EXPIRES_IN=7d

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your-company-email@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Server Configuration
PORT=3001

# Optional: Cloudinary (if using file uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
