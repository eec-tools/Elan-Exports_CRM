# RDS PostgreSQL connection string
DATABASE_URL=
# JWT
JWT_SECRET=your-256-bit-secret-change-this
JWT_EXPIRES_IN=7d

# SMTP (for sending credential emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Frontend URL (for CORS + email links) - comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173,https://crm.eectrade.com

# Node environment
NODE_ENV=production

# Server port
PORT=3001

# ─── Agent 1: Buyer Discovery ────────────────────────────────────────────────
# Snov.io — primary email finder & prospect search (Settings → API in Snov.io dashboard)
SNOV_CLIENT_ID=your-snov-client-id
SNOV_CLIENT_SECRET=your-snov-client-secret

# Groq — LLM discovery fallback + lead scoring (console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Firecrawl — website scraping for email extraction (firecrawl.dev)
FIRECRAWL_API_KEY=

# Hunter.io — legacy email fallback (optional, leave blank if using Snov.io)
HUNTER_API_KEY=

# Apollo.io — optional lead search (leave blank on free plan)
APOLLO_API_KEY=

# ─── Microsoft Outlook / Graph API (Email Sync) ───────────────────────────────
# Azure App Registration — requires Mail.Read *application* permission on the mailbox
# Leave blank to disable the Outlook sync scheduler (the app will still run normally)
OUTLOOK_TENANT_ID=your-azure-tenant-id
OUTLOOK_CLIENT_ID=your-app-registration-client-id
OUTLOOK_CLIENT_SECRET=your-app-registration-client-secret
OUTLOOK_MAILBOX=sales@yourcompany.com
