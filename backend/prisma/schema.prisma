generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String                  @map("password_hash")
  fullName               String                  @map("full_name")
  isActive               Boolean                 @default(true) @map("is_active")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  workStartTime          String                  @default("09:00") @map("work_start_time")
  workEndTime            String                  @default("18:00") @map("work_end_time")
  minHoursPresent        Int                     @default(420) @map("min_hours_present")
  assignedCompanies      String[]                @default([]) @map("assigned_companies")
  bankAccountNumber      String?                 @map("bank_account_number")
  bankIfsc               String?                 @map("bank_ifsc")
  bankName               String?                 @map("bank_name")
  designation            String?
  employeeStatus         EmployeeStatus          @default(probation) @map("employee_status")
  gender                 Gender?
  monthlySalary          Float?                  @map("monthly_salary")
  saturdaySchedule       String                  @default("off") @map("saturday_schedule")
  reviewedRequests       AccessRequest[]         @relation("reviewer")
  accessRequests         AccessRequest[]         @relation("requester")
  activityEvents         ActivityEvent[]
  activityLogs           ActivityLog[]
  attendanceBeats        AttendanceHeartbeat[]
  attendances            Attendance[]
  buyerVaultContacts     BuyerVaultContact[]
  buyerVaultFolders      BuyerVaultFolder[]
  buyers                 Buyer[]
  deals                  Deal[]
  leaves                 Leave[]
  notificationReads      NotificationRead[]
  payrolls               Payroll[]
  reports                Report[]
  sourcingBuyers         SourcingBuyer[]
  sourcingSuppliers      SourcingSupplier[]
  sourcingVaultFolders   SourcingVaultFolder[]
  sourcingVaultSuppliers SourcingVaultSupplier[]
  suppliers              Supplier[]
  permissions            UserPermission[]
  roles                  UserRole[]
  vaultDocumentVersions  VaultDocumentVersion[]
  vaultDocuments         VaultDocument[]

  @@map("users")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model UserPermission {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  permission  Permission
  accessLevel AccessLevel @default(edit) @map("access_level")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("user_permissions")
}

model Buyer {
  id                        String      @id @default(uuid())
  company                   String
  name                      String
  email                     String
  phone                     String?
  country                   String
  address                   String?
  website                   String?
  region                    String?
  productCategoryInterest   String?     @map("product_category_interest")
  moqRequirements           String?     @map("moq_requirements")
  pricingRange              String?     @map("pricing_range")
  certificationRequirements String?     @map("certification_requirements")
  paymentTerms              String?     @map("payment_terms")
  incoterms                 String?
  riskRating                String?     @map("risk_rating")
  strategicValue            String?     @map("strategic_value")
  leadSource                String?     @map("lead_source")
  lastContactDate           DateTime?   @map("last_contact_date") @db.Date
  dealHistory               String?     @map("deal_history")
  notes                     String?
  status                    String?     @default("Pending")
  requiredProducts          Json        @default("[]") @map("required_products")
  createdBy                 String?     @map("created_by")
  createdAt                 DateTime    @default(now()) @map("created_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")
  additionalContacts        Json?       @map("additional_contacts")
  annualImportVolume        String?     @map("annual_import_volume")
  annualPurchaseValue       String?     @map("annual_purchase_value")
  buyerType                 String?     @map("buyer_type")
  city                      String?
  contactRole               String?     @map("contact_role")
  countryOfFinalDelivery    String?     @map("country_of_final_delivery")
  currentSuppliersOrigins   String?     @map("current_suppliers_origins")
  freightForwarder          String?     @map("freight_forwarder")
  howHeardAboutUs           String?     @map("how_heard_about_us")
  marketsServed             String?     @map("markets_served")
  packingRequirements       String?     @map("packing_requirements")
  portsOfDischarge          String?     @map("ports_of_discharge")
  preferredCurrency         String?     @map("preferred_currency")
  productCategories         String?     @map("product_categories")
  shippingMode              String?     @map("shipping_mode")
  socialEthicalCompliance   String?     @map("social_ethical_compliance")
  sourcingRequirements      Json?       @map("sourcing_requirements")
  tradeFairName             String?     @map("trade_fair_name")
  tradeName                 String?     @map("trade_name")
  whatsapp                  String?
  productCatalog            String?     @map("product_catalog_shared")
  supplierLinks             Json        @default("[]") @map("supplier_links")
  quotations                Json?       @default("[]") @map("quotations")
  relationshipTier          String?     @map("relationship_tier")
  initialOrderValue         String?     @map("initial_order_value")
  potentialAnnualValue      String?     @map("potential_annual_value")
  reorderLikelihood         String?     @map("reorder_likelihood")
  buyerStatedIntent         String?     @map("buyer_stated_intent")
  documents                 Json        @default("[]") @map("documents")
  creator                   User?       @relation(fields: [createdBy], references: [id])
  quotationLinks            Quotation[]

  @@map("buyers")
}

