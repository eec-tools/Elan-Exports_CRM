  buyerName              String?   @map("buyer_name")
  currency               String?
  linkedDealId           String?   @map("linked_deal_id")
  quotedPrice            String?   @map("quoted_price")
  validUntil             DateTime? @map("valid_until") @db.Date
  buyer                  Buyer?    @relation(fields: [buyerId], references: [id])

  @@map("quotations")
}

model SourcingVaultFolder {
  id        String                  @id @default(uuid())
  name      String                  @unique
  createdBy String?                 @map("created_by")
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")
  creator   User?                   @relation(fields: [createdBy], references: [id])
  suppliers SourcingVaultSupplier[]

  @@map("sourcing_vault_folders")
}

model SourcingVaultSupplier {
  id            String              @id @default(uuid())
  folderId      String              @map("folder_id")
  company       String
  email         String?
  phone         String?
  contactPerson String?             @map("contact_person")
  country       String?
  product       String?
  notes         String?
  emailStatus   String              @default("Not Sent") @map("email_status")
  createdBy     String?             @map("created_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  creator       User?               @relation(fields: [createdBy], references: [id])
  folder        SourcingVaultFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@map("sourcing_vault_suppliers")
}

model BuyerVaultFolder {
  id        String              @id @default(uuid())
  name      String              @unique
  createdBy String?             @map("created_by")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  contacts  BuyerVaultContact[]
  creator   User?               @relation(fields: [createdBy], references: [id])

  @@map("buyer_vault_folders")
}

model BuyerVaultContact {
  id                     String           @id @default(uuid())
  folderId               String           @map("folder_id")
  company                String
  website                String?
  email                  String?
  phone                  String?
  contactPerson          String?          @map("contact_person")
  linkedin               String?
  country                String?
  product                String?
  keyPainPoints          String?          @map("key_pain_points")
  emailTemplate          String?          @map("email_template")
  personalizationQuality String?          @map("personalization_quality")
  notes                  String?
  emailStatus            String           @default("Not Sent") @map("email_status")
  createdBy              String?          @map("created_by")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  creator                User?            @relation(fields: [createdBy], references: [id])
  folder                 BuyerVaultFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@map("buyer_vault_contacts")
}

model SourcingBuyer {
  id                   String                      @id @default(uuid())
  company              String
  email                String?
  phone                String?
  contactPerson        String?                     @map("contact_person")
  country              String?
  product              String?
  productCategory      String?                     @map("product_category")
  notes                String?
  status               String                      @default("pending")
  assignedGmailAccount String?                     @map("assigned_gmail_account")
  emailTemplateId      String?                     @map("email_template_id")
  customEmailBody      String?                     @map("custom_email_body")
  createdBy            String?                     @map("created_by")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  buyerVaultContactId  String?                     @map("buyer_vault_contact_id")
  alreadyContacted     Boolean                     @default(false) @map("already_contacted")
  emailCampaign        SourcingBuyerEmailCampaign?
  emailReplies         BuyerEmailReply[]
  creator              User?                       @relation(fields: [createdBy], references: [id])

  @@map("sourcing_buyers")
}

model SourcingBuyerEmailCampaign {
  id                 String        @id @default(uuid())
  sourcingBuyerId    String        @unique @map("sourcing_buyer_id")
  status             String        @default("active")
  currentStep        Int           @default(1) @map("current_step")
  introEmailSentAt   DateTime      @map("intro_email_sent_at")
  followup1SentAt    DateTime?     @map("followup1_sent_at")
  followup2SentAt    DateTime?     @map("followup2_sent_at")
  followup3SentAt    DateTime?     @map("followup3_sent_at")
  responseReceivedAt DateTime?     @map("response_received_at")
  nextFollowupDue    DateTime?     @map("next_followup_due")
  gmailThreadId      String?       @map("gmail_thread_id")
  gmailMessageId     String?       @map("gmail_message_id")
  lastCheckedAt      DateTime?     @map("last_checked_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  sourcingBuyer      SourcingBuyer @relation(fields: [sourcingBuyerId], references: [id], onDelete: Cascade)

  @@map("sourcing_buyer_email_campaigns")
}

model BuyerEmailReply {
  id              String         @id @default(uuid())
  sourcingBuyerId String?        @map("sourcing_buyer_id")
  gmailMessageId  String?        @map("gmail_message_id")
  direction       String         @default("received") @map("direction")
  fromEmail       String         @map("from_email")
  fromName        String?        @map("from_name")
  subject         String?
  body            String
  receivedAt      DateTime       @map("received_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  repliedAt       DateTime?      @map("replied_at")
  sourcingBuyer   SourcingBuyer? @relation(fields: [sourcingBuyerId], references: [id], onDelete: SetNull)

  @@map("buyer_email_replies")
}

