// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ───────────────────────────────────

enum Role {
  admin
  member
}

enum Permission {
  buyers
  suppliers
  analytics
  reports
  vault
  task_tracker
}

enum AccessLevel {
  read
  edit
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String           @map("password_hash")
  fullName       String           @map("full_name")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  roles            UserRole[]
  permissions      UserPermission[]
  activityLogs     ActivityLog[]
  accessRequests   AccessRequest[]  @relation("requester")
  reviewedRequests AccessRequest[]  @relation("reviewer")
  buyers           Buyer[]
  suppliers        Supplier[]
  reports          Report[]
  vaultDocuments   VaultDocument[]
  deals            Deal[]

  @@map("users")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  role   Role

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model UserPermission {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  permission  Permission
  accessLevel AccessLevel @default(edit) @map("access_level")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("user_permissions")
}

// ─── BUYERS ─────────────────────────────────────────

model Buyer {
  id                        String    @id @default(uuid())
  company                   String
  name                      String
  email                     String
  phone                     String?
  country                   String
  address                   String?
  website                   String?
  region                    String?
  productCategoryInterest   String?   @map("product_category_interest")
  moqRequirements           String?   @map("moq_requirements")
  pricingRange              String?   @map("pricing_range")
  certificationRequirements String?   @map("certification_requirements")
  paymentTerms              String?   @map("payment_terms")
  incoterms                 String?
  riskRating                String?   @map("risk_rating")
  strategicValue            String?   @map("strategic_value")
  leadSource                String?   @map("lead_source")
  lastContactDate           DateTime? @map("last_contact_date") @db.Date
  dealHistory               String?   @map("deal_history")
  notes                     String?
  status                    String?   @default("Pending")
  requiredProducts          Json      @default("[]") @map("required_products")

  createdBy                 String?   @map("created_by")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  creator                   User?     @relation(fields: [createdBy], references: [id])

  @@map("buyers")
}

// ─── SUPPLIERS ──────────────────────────────────────

model Supplier {
  id                     String   @id @default(uuid())
  company                String
  lidlFactoryId          String?  @map("lidl_factory_id")
  commissionPercent      String?  @map("commission_percent")
  contractBuyer          String?  @map("contract_buyer")
  approvedConfirmPercent String?  @map("approved_confirm_percent")
  products               String?
  country                String?
  contactPerson          String?  @map("contact_person")
  phone                  String?
  companyAddress         String?  @map("company_address")
  email                  String?
  website                String?
  productCatalogShared   String?  @map("product_catalog_shared")
  productionCapacity     String?  @map("production_capacity")
  factoryVideosShared    String?  @map("factory_videos_shared")
  warehouseVideosShared  String?  @map("warehouse_videos_shared")
  exportingCountries     String?  @map("exporting_countries")
  samplePolicy           String?  @map("sample_policy")
  certifications         String?
  workingWithOurBrands   String?  @map("working_with_our_brands")
  otherBrands            String?  @map("other_brands")
  remarks                String?
  currentStatus          String?  @default("Active") @map("current_status")
  documents              Json     @default("[]")

  createdBy              String?  @map("created_by")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  creator                User?    @relation(fields: [createdBy], references: [id])

  @@map("suppliers")
}

// ─── OLD SUPPLIERS ──────────────────────────────────

model OldSupplier {
  id                    String   @id @default(uuid())
  company               String
  productCategory       String?  @map("product_category")
  product               String?
  country               String?
  accountManager        String?  @map("account_manager")
  currentStatus         String?  @map("current_status")
  certifications        String?
  latestQuotation       String?  @map("latest_quotation")
  reasonInactive        String?  @map("reason_inactive")
  dateMarkedInactive    String?  @map("date_marked_inactive")
  reactivationPotential String?  @map("reactivation_potential")
  notes                 String?

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("old_suppliers")
}

// ─── REPORTS ────────────────────────────────────────

model Report {
  id              String    @id @default(uuid())
  productName     String    @map("product_name")
  productImageUrl String?   @map("product_image_url")
  buyerName       String    @map("buyer_name")
  companyName     String    @map("company_name")
  status          String
  keyUpdates      String?   @map("key_updates")
  updateDate      DateTime? @map("update_date") @db.Date
  buyerSupplier   String    @default("Buyer") @map("buyer_supplier")
  reportDate      DateTime  @map("report_date") @db.Date

  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creator         User?     @relation(fields: [createdBy], references: [id])

  @@map("reports")
}

// ─── ACTIVITY LOGS ──────────────────────────────────

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ─── ACCESS REQUESTS ────────────────────────────────

model AccessRequest {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  permission String
  reason     String
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  reviewedAt DateTime? @map("reviewed_at")
  reviewedBy String?   @map("reviewed_by")

  user       User      @relation("requester", fields: [userId], references: [id])
  reviewer   User?     @relation("reviewer", fields: [reviewedBy], references: [id])

  @@map("access_requests")
}

// ─── APP SETTINGS ───────────────────────────────────

model AppSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_settings")
}

// ─── EMAIL TASK TRACKER ─────────────────────────────

model EmailTracker {
  id               String    @id @default(uuid())
  dateReceived     DateTime  @map("date_received")
  senderAddress    String    @map("sender_address")
  subject          String
  task             String?
  productCategory  String?   @map("product_category")
  priority         String?
  respondent       String?
  status           String    @default("Not Started")
  notes            String?
  emailLink        String?   @map("email_link")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("email_tracker")
}

// ─── VAULT DOCUMENTS ────────────────────────────────

model VaultDocument {
  id          String   @id @default(uuid())
  name        String
  category    String
  region      String   @default("Global")
  fileUrl     String   @map("file_url")
  publicId    String   @map("public_id")
  fileType    String   @map("file_type")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  uploader    User?   @relation(fields: [uploadedBy], references: [id])

  @@map("vault_documents")
}

// ─── DAILY TASK TRACKER ─────────────────────────────

model DailyTask {
  id        String    @id @default(uuid())
  date      DateTime  @db.Date
  taskText  String    @map("task_text")
  company   String?
  priority  String?
  owner     String?
  status    String    @default("Not Started")
  deadline  DateTime? @db.Date
  notes     String?
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("daily_tasks")
}

// ─── DEALS ──────────────────────────────────────────

model Deal {
  id              String   @id @default(uuid())
  title           String
  buyer           String?
  supplier        String?
  product         String?
  hsCode          String?  @map("hs_code")
  volume          String?
  price           Float?
  expectedRevenue Float?   @map("expected_revenue")
  margin          Float?   @default(15)
  stage           String   @default("LEAD")
  probability     Float?   @default(20)
  category        String?
  riskScore       String?  @default("Medium") @map("risk_score")
  notes           String?

  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  creator              User?                 @relation(fields: [createdBy], references: [id])
  complianceDocuments  ComplianceDocument[]

  @@map("deals")
}

// ─── COMPLIANCE ──────────────────────────────────────

enum ComplianceStatus {
  RECEIVED
  PENDING
  MISSING
}

model ComplianceDocument {
  id        String           @id @default(uuid())
  dealId    String           @map("deal_id")
  docType   String           @map("doc_type")
  status    ComplianceStatus @default(MISSING)
  dueDate   DateTime?        @map("due_date") @db.Date
  notes     String?

  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  deal      Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("compliance_documents")
}
