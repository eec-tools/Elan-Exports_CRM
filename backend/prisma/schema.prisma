model NewSupplierEmailCampaign {
  id                 String      @id @default(uuid())
  newSupplierId      String      @unique @map("new_supplier_id")
  status             String      @default("active")
  // status: "active" | "completed" | "response_received"
  currentStep        Int         @default(1) @map("current_step")
  // 1 = intro sent, 2 = followup1 sent, 3 = followup2 sent, 4 = followup3 sent (completed)
  introEmailSentAt   DateTime    @map("intro_email_sent_at")
  followup1SentAt    DateTime?   @map("followup1_sent_at")
  followup2SentAt    DateTime?   @map("followup2_sent_at")
  followup3SentAt    DateTime?   @map("followup3_sent_at")
  responseReceivedAt DateTime?   @map("response_received_at")
  nextFollowupDue    DateTime?   @map("next_followup_due")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  newSupplier        NewSupplier @relation(fields: [newSupplierId], references: [id], onDelete: Cascade)

  @@map("new_supplier_email_campaigns")
}

model Report {
  id              String    @id @default(uuid())
  productName     String    @map("product_name")
  productImageUrl String?   @map("product_image_url")
  buyerName       String    @map("buyer_name")
  companyName     String    @map("company_name")
  status          String
  keyUpdates      String?   @map("key_updates")
  updateDate      DateTime? @map("update_date") @db.Date
  buyerSupplier   String    @default("Buyer") @map("buyer_supplier")
  reportDate      DateTime  @map("report_date") @db.Date
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  creator         User?     @relation(fields: [createdBy], references: [id])
  dealStage       String?   @map("deal_stage")

  @@map("reports")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model AccessRequest {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  permission String
  reason     String
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  reviewedAt DateTime? @map("reviewed_at")
  reviewedBy String?   @map("reviewed_by")
  reviewer   User?     @relation("reviewer", fields: [reviewedBy], references: [id])
  user       User      @relation("requester", fields: [userId], references: [id])

  @@map("access_requests")
}

model AppSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_settings")
}

model EmailTracker {
  id              String   @id @default(uuid())
  dateReceived    DateTime @map("date_received")
  senderAddress   String   @map("sender_address")
  subject         String
  task            String?
  productCategory String?  @map("product_category")
  priority        String?
  respondent      String?
  status          String   @default("Not Started")
  notes           String?
  emailLink       String?  @map("email_link")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("email_tracker")
}

model VaultDocument {
  id         String          @id @default(uuid())
  name       String
  category   String
  region     String          @default("Global")
  fileUrl    String?         @map("file_url")
  publicId   String?         @map("public_id")
  fileType   String?         @map("file_type")
  isFolder   Boolean         @default(false) @map("is_folder")
  parentId   String?         @map("parent_id")
  parent     VaultDocument?  @relation("VaultTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   VaultDocument[] @relation("VaultTree")
  uploadedBy String?         @map("uploaded_by")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  uploader   User?           @relation(fields: [uploadedBy], references: [id])

  @@map("vault_documents")
}

model DailyTask {
  id        String    @id @default(uuid())
  date      DateTime  @db.Date
  taskText  String    @map("task_text")
  company   String?
  priority  String?
  owner     String?
  status    String    @default("Not Started")
  deadline  DateTime? @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("daily_tasks")
}

model Deal {
  id                  String               @id @default(uuid())
  title               String
  buyer               String?
  supplier            String?
  product             String?
  hsCode              String?              @map("hs_code")
  volume              String?
  price               Float?
  expectedRevenue     Float?               @map("expected_revenue")
  margin              Float?               @default(15)
  stage               String               @default("Communication")
  probability         Float?               @default(20)
  category            String?
  riskScore           String?              @default("Medium") @map("risk_score")
  notes               String?
  createdBy           String?              @map("created_by")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  complianceDocuments ComplianceDocument[]
  creator             User?                @relation(fields: [createdBy], references: [id])

  @@map("deals")
}

model ComplianceDocument {
  id        String           @id @default(uuid())
  dealId    String           @map("deal_id")
  docType   String           @map("doc_type")
  status    ComplianceStatus @default(MISSING)
  dueDate   DateTime?        @map("due_date") @db.Date
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deal      Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("compliance_documents")
}

enum Role {
  admin
  member
}

model Notification {
  id         String             @id @default(uuid())
  type       String
  title      String
  message    String
  entityType String             @map("entity_type")
  entityId   String             @map("entity_id")
  entityName String             @map("entity_name")
  entityLink String?            @map("entity_link")
  createdBy  String?            @map("created_by")
  createdAt  DateTime           @default(now()) @map("created_at")
  reads      NotificationRead[]

  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(uuid())
  notificationId String       @map("notification_id")
  userId         String       @map("user_id")
  readAt         DateTime     @default(now()) @map("read_at")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

enum Permission {
  buyers
  suppliers
  analytics
  reports
  vault
  task_tracker
  email_tracker
  deals
  new_suppliers
  signed_suppliers
  old_suppliers
}

enum AccessLevel {
  read
  edit
}

enum ComplianceStatus {
  RECEIVED
  PENDING
  MISSING
}
